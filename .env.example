# Environment variables configuration for the observable AI chatbot
# Copy this file to .env and fill in your actual values

# OpenRouter API key - required for making LLM API calls
# Get your free API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Custom model to use by default (if not specified, uses Llama 3.3 70B)
# DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Optional: Maximum tokens for LLM responses
# MAX_TOKENS=1000

# Optional: Temperature for LLM responses (0.0-1.0)
# TEMPERATURE=0.7
